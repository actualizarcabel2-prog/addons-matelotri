<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.addons.matelotri" name="Addons Matelotri" version="1.0.0" provider-name="Matelotri">
    <extension point="xbmc.addon.repository" name="Addons Matelotri">
        <dir>
            <info compressed="false">https://actualizarcabel2-prog.github.io/addons-matelotri/addons.xml</info>
            <checksum>https://actualizarcabel2-prog.github.io/addons-matelotri/addons.xml.md5</checksum>
            <datadir zip="true">https://actualizarcabel2-prog.github.io/addons-matelotri/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <summary lang="es_ES">Repositorio de Addons Matelotri</summary>
        <description lang="es_ES">Repositorio oficial de addons Matelotri Cinema para Kodi.</description>
    </extension>
</addon>
<addon id="plugin.video.matelotricinema" name="[COLOR gold]Matelotri Cinema[/COLOR]" version="1.0.0" provider-name="Matelotri">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <description lang="es_ES">Matelotri Cinema - Tu cine en casa.</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.png</fanart>
    </assets>
  </extension>
</addon>
</addons>