<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="repository.addons.matelotri" name="Matelotri Repository" version="1.1.9" provider-name="Matelotri">
    <requires><import addon="xbmc.addon" version="12.0.0"/></requires>
    <extension point="xbmc.addon.repository" name="Matelotri Repository">
      <dir>
        <info compressed="false">https://actualizarcabel2-prog.github.io/addons-matelotri/addons.xml</info>
        <checksum>https://actualizarcabel2-prog.github.io/addons-matelotri/addons.xml.md5</checksum>
        <datadir zip="true">https://actualizarcabel2-prog.github.io/addons-matelotri/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary>Matelotri Repository</summary>
      <description>Repositorio oficial de Matelotri Cinema</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="plugin.video.matelotricinema" name="Matelotri Cinema" version="1.0.2" provider-name="Matelotri">
    <requires><import addon="xbmc.python" version="3.0.0"/></requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <description lang="es_ES">Matelotri Cinema - Tu cine en casa. Peliculas, Series, Anime en 4K.</description>
      <platform>all</platform>
      <assets><icon>icon.png</icon><fanart>fanart.png</fanart></assets>
    </extension>
  </addon>
</addons>
